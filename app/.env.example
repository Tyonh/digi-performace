# Copie para .env.local e preencha. NÃO commite o .env.local.

# URL do PROJETO Supabase — apenas o domínio, SEM /rest/v1/ no final.
# Certo:  https://xxxxxxxx.supabase.co
# Errado: https://xxxxxxxx.supabase.co/rest/v1/   ← supabase-js adiciona isso sozinho
EXPO_PUBLIC_SUPABASE_URL=

# Chave pública (anon / publishable). Protegida pela RLS — pode ir no app.
# Formato: sb_publishable_... (nova) ou eyJ... (JWT legado).
EXPO_PUBLIC_SUPABASE_ANON_KEY=
